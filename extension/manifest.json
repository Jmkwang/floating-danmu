{
  "manifest_version": 3,
  "name": "Floating Danmu",
  "version": "1.0.0",
  "description": "B站弹幕悬浮发送工具 - 通过桌面悬浮窗口发送弹幕",
  "permissions": [
    "activeTab",
    "tabs",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://*.bilibili.com/*",
    "https://broadcastlv.chat.bilibili.com/*",
    "http://localhost:34567/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://live.bilibili.com/*",
        "https://www.bilibili.com/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Floating Danmu"
  }
}